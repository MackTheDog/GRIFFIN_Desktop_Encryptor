# -----------------------------------------------------------------------------
# -- CRYPTO SERVICE CLASS (PURE BINARY PAYLOAD + CHACHA20POLY1305)
# -----------------------------------------------------------------------------
class CryptoService:
    CHUNK_SIZE = 16 * 1024 * 1024  # 16MB raw chunks
    PADDING_BLOCK_SIZE = 16384     # 16KB side-channel mitigation alignment
    KEY_BYTES = 32
    SALT_BYTES = 32
    NONCE_BYTES = 12

    def _zero_bytearray(self, b: bytearray) -> None:
        """Overwrites volatile memory blocks directly."""
        if b:
            for i in range(len(b)):
                b[i] = 0
        gc.collect()

    def generate_master_key(self, password_str: str, salt: bytes, level: str) -> bytearray:
        """Derives Argon2id master key mapped to strict standard memory boundaries."""
        if level == "Fast":
            time_cost, memory_cost, parallelism = 2, 256 * 1024, 2      # 256MB
        else: 
            time_cost, memory_cost, parallelism = 3, 512 * 1024, 2      # 512MB (Normal)
           
        raw_pwd = bytearray(password_str.encode('utf-8'))
        try:
            raw_key = argon2.low_level.hash_secret_raw(
                secret=bytes(raw_pwd), salt=salt, 
                time_cost=time_cost,
                memory_cost=memory_cost, parallelism=parallelism,
                hash_len=self.KEY_BYTES, type=argon2.low_level.Type.ID
            )
            return bytearray(raw_key)
        finally:
            if isinstance(raw_pwd, bytearray):
                self._zero_bytearray(raw_pwd)

    def derive_ephemeral_key(self, master_key: bytearray, info_str: str) -> bytearray:
        hkdf = HKDF(
            algorithm=hashes.SHA256(),
            length=self.KEY_BYTES,
            salt=None,
            info=info_str.encode('utf-8')
        )
        derived = hkdf.derive(bytes(master_key))
        return bytearray(derived)

    def secure_shred_file(self, filepath: str):
        """Executes a defensive 1-pass random overwrite to destroy file patterns."""
        try:
            if os.path.isfile(filepath):
                file_size = os.path.getsize(filepath)
                if file_size > 0:
                    with open(filepath, "r+b") as f:
                        f.seek(0)
                        bytes_left = file_size
                        while bytes_left > 0:
                            chunk_to_write = min(bytes_left, self.CHUNK_SIZE)
                            f.write(os.urandom(chunk_to_write))
                            bytes_left -= chunk_to_write
                        f.flush()
                        os.fsync(f.fileno())
                
                with open(filepath, "wb") as f:
                    pass
                os.remove(filepath)
        except Exception:
            pass 

    def encrypt_paths(self, password: str, input_paths: List[str], level: str, shred_source: bool = False, secure_note: str = "") -> Generator[Tuple[int, int], None, str]:
        desktop_path = os.path.join(os.path.expanduser('~'), 'Desktop')
        timestamp = datetime.now().strftime("%Y-%m-%d_%H%M%S")
        output_filename = f"secure_package_{timestamp}.grn"
        final_output_path = os.path.join(desktop_path, output_filename)
        
        file_list = list(self._get_all_filepaths(input_paths))
        total_unencrypted_size = sum(os.path.getsize(fp) for fp, _ in file_list)
        
        note_bytes = b""
        if secure_note:
            note_bytes = secure_note.encode('utf-8')
            total_unencrypted_size += len(note_bytes)
            
        processed_size = 0
        salt = os.urandom(self.SALT_BYTES)
        master_key = self.generate_master_key(password, salt, level)
        
        try:
            fat_entries = []
            
            with open(final_output_path, 'wb') as f_out:
                f_out.write(salt)
                
                # Encrypt allocated files
                for index, (full_path, relative_path) in enumerate(file_list):
                    yield processed_size, total_unencrypted_size
                    file_key = self.derive_ephemeral_key(master_key, f"file_payload_{index}")
                    
                    payload_start_offset = f_out.tell()
                    real_size = os.path.getsize(full_path)
                    
                    chunks_meta = []
                    chacha = ChaCha20Poly1305(bytes(file_key))
                    
                    with open(full_path, 'rb') as f_in:
                        while True:
                            raw_chunk = f_in.read(self.CHUNK_SIZE)
                            if not raw_chunk:
                                break
                            
                            compressed_chunk = zlib.compress(raw_chunk, level=6)
                            comp_len = len(compressed_chunk)
                            
                            payload_to_pad = comp_len.to_bytes(4, 'big') + compressed_chunk
                            
                            pad_mod = len(payload_to_pad) % self.PADDING_BLOCK_SIZE
                            pad_needed = (self.PADDING_BLOCK_SIZE - pad_mod) % self.PADDING_BLOCK_SIZE
                            padded_chunk = payload_to_pad + os.urandom(pad_needed)
                            
                            nonce = os.urandom(self.NONCE_BYTES)
                            encrypted_chunk = chacha.encrypt(nonce, padded_chunk, None)
                            
                            chunks_meta.append({
                                'nonce_hex': nonce.hex(),
                                'size': len(encrypted_chunk)
                            })
                            
                            f_out.write(encrypted_chunk)
                            yield processed_size + len(raw_chunk), total_unencrypted_size
                    
                    fat_entries.append({
                        'filename': relative_path,
                        'real_size': real_size,
                        'payload_offset': payload_start_offset,
                        'chunks': chunks_meta,
                        'is_virtual': False
                    })
                    
                    processed_size += real_size
                    self._zero_bytearray(file_key)
                
                # Append inline typed Drop Box text as README.txt
                if note_bytes:
                    yield processed_size, total_unencrypted_size
                    v_index = len(file_list)
                    note_real_size = len(note_bytes)
                    
                    note_key = self.derive_ephemeral_key(master_key, f"file_payload_{v_index}")
                    note_payload_offset = f_out.tell()
                    
                    chacha_v = ChaCha20Poly1305(bytes(note_key))
                    comp_note = zlib.compress(note_bytes, level=6)
                    comp_v_len = len(comp_note)
                    
                    v_payload_to_pad = comp_v_len.to_bytes(4, 'big') + comp_note
                    v_pad_mod = len(v_payload_to_pad) % self.PADDING_BLOCK_SIZE
                    v_pad_needed = (self.PADDING_BLOCK_SIZE - v_pad_mod) % self.PADDING_BLOCK_SIZE
                    padded_v_chunk = v_payload_to_pad + os.urandom(v_pad_needed)
                    
                    v_nonce = os.urandom(self.NONCE_BYTES)
                    encrypted_v_chunk = chacha_v.encrypt(v_nonce, padded_v_chunk, None)
                    
                    fat_entries.append({
                        'filename': "README.txt",
                        'real_size': note_real_size,
                        'payload_offset': note_payload_offset,
                        'chunks': [{
                            'nonce_hex': v_nonce.hex(),
                            'size': len(encrypted_v_chunk)
                        }],
                        'is_virtual': True
                    })
                    f_out.write(encrypted_v_chunk)
                    processed_size += note_real_size
                    self._zero_bytearray(note_key)

                # Append encrypted FAT architecture structure map
                fat_bytes = json.dumps(fat_entries).encode('utf-8')
                fat_key = self.derive_ephemeral_key(master_key, "fat_header_encryption")
                
                chacha_fat = ChaCha20Poly1305(bytes(fat_key))
                fat_nonce = os.urandom(self.NONCE_BYTES)
                encrypted_fat = chacha_fat.encrypt(fat_nonce, fat_bytes, None)
                self._zero_bytearray(fat_key)
                
                fat_base_pointer = f_out.tell()
                f_out.write(fat_nonce)
                f_out.write(encrypted_fat)
                f_out.write(fat_base_pointer.to_bytes(8, 'big'))
            
            if shred_source:
                for full_path, _ in file_list:
                    self.secure_shred_file(full_path)
                 
            yield total_unencrypted_size, total_unencrypted_size
            return final_output_path
          
        finally:
            self._zero_bytearray(master_key)

    def decrypt_archive(self, password: str, input_path: str, output_directory: str, level: str) -> Generator[Tuple[int, int], None, str]:
        with open(input_path, 'rb') as f_in:
            salt = f_in.read(self.SALT_BYTES)
            master_key = self.generate_master_key(password, salt, level)
            
            try:
                f_in.seek(-8, os.SEEK_END)
                fat_base_pointer = int.from_bytes(f_in.read(8), 'big')
                
                f_in.seek(fat_base_pointer)
                fat_nonce = f_in.read(self.NONCE_BYTES)
                encrypted_fat = f_in.read()[:-8]
                
                fat_key = self.derive_ephemeral_key(master_key, "fat_header_encryption")
                chacha_fat = ChaCha20Poly1305(bytes(fat_key))
                
                fat_json = chacha_fat.decrypt(fat_nonce, encrypted_fat, None)
                fat_entries = json.loads(fat_json)
                self._zero_bytearray(fat_key)
                
                processed_bytes = 0
                total_target_payload_bytes = sum(entry['real_size'] for entry in fat_entries)
                yield 0, total_target_payload_bytes

                for index, entry in enumerate(fat_entries):
                    relative_filename = entry['filename']
                    payload_offset = entry['payload_offset']
                    chunks = entry['chunks']
                    
                    clean_rel_path = relative_filename.replace("/", os.sep)
                    output_filepath = os.path.normpath(os.path.join(output_directory, clean_rel_path))
                    base_target_path = os.path.abspath(output_directory)
                   
                    if not os.path.abspath(output_filepath).startswith(base_target_path):
                        raise PermissionError(f"Directory traversal compromise caught: {relative_filename}")
                        
                    if os.path.exists(output_filepath):
                        dir_part = os.path.dirname(output_filepath)
                        name_part, extension_part = os.path.splitext(os.path.basename(output_filepath))
                        counter = 1
                        while os.path.exists(output_filepath):
                            unique_name = f"{name_part} ({counter}){extension_part}"
                            output_filepath = os.path.join(dir_part, unique_name)
                            counter += 1

                    os.makedirs(os.path.dirname(output_filepath), exist_ok=True)
                    f_in.seek(payload_offset)
                    
                    file_key = self.derive_ephemeral_key(master_key, f"file_payload_{index}")
                    chacha = ChaCha20Poly1305(bytes(file_key))
                    
                    with open(output_filepath, 'wb') as f_out:
                        for chunk in chunks:
                            nonce = bytes.fromhex(chunk['nonce_hex'])
                            enc_size = chunk['size']
                            
                            encrypted_data = f_in.read(enc_size)
                            decrypted_padded = chacha.decrypt(nonce, encrypted_data, None)
                            
                            comp_len = int.from_bytes(decrypted_padded[:4], 'big')
                            compressed_chunk = decrypted_padded[4:4+comp_len]
                            
                            raw_data = zlib.decompress(compressed_chunk)
                            f_out.write(raw_data)
                            
                            processed_bytes += len(raw_data)
                            yield min(processed_bytes, total_target_payload_bytes), total_target_payload_bytes
                            
                    self._zero_bytearray(file_key)
            finally:
                self._zero_bytearray(master_key)
                
        return output_directory

    @staticmethod
    def _get_all_filepaths(paths: List[str]) -> Generator[Tuple[str, str], None, None]:
        for path in paths:
            if os.path.isfile(path):
                yield path, os.path.basename(path)
            elif os.path.isdir(path):
                root_dir = os.path.dirname(path)
                for base_dir, _, filenames in os.walk(path):
                    for filename in filenames:
                        full_path = os.path.join(base_dir, filename)
                        relative_path = os.path.relpath(full_path, root_dir)
                        unified_path = relative_path.replace(os.sep, "/")
                        yield full_path, unified_path


