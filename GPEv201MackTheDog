        if selected_mode == "Decrypt":
            self.confirm_entry.pack_forget()
            self.shred_checkbox.pack_forget()
            self.inline_warning_frame.pack_forget()
            self.process_button.configure(text="Unlock & Extract", fg_color="#3b82f6", hover_color="#2563eb")
        else:
            self.confirm_entry.pack(after=self.p1_row_wrapper, fill="x", pady=4)
            self.shred_checkbox.pack(side="right", padx=(10, 5))
            if self.shred_checkbox_var.get():
                self.inline_warning_frame.pack(after=self.config_frame, fill="x", padx=30, pady=(0, 10))
            self.process_button.configure(text="Lock Package", fg_color="#10b981", hover_color="#059669")
        
        # Enforce character configuration settings explicitly
        self.password_entry.configure(show=current_mask_char)
        self.confirm_entry.configure(show=current_mask_char)
        
        if force_clear:
            self.update_display_text()
        self._validate_passwords()

    def _validate_passwords(self, event=None) -> bool:
        mode = self.mode_var.get()
        p1 = self.password_entry.get()
        p2 = self.confirm_entry.get()
        
        if len(p1) < 8:
            self.status_feedback_label.configure(text="⚠️ Password must be at least 8 characters.", text_color="#eb4d4b")
            self.process_button.configure(state="disabled")
            return False
             
        if mode == "Encrypt":
            if p1 != p2:
                self.status_feedback_label.configure(text="❌ Passwords do not match.", text_color="#eb4d4b")
                self.process_button.configure(state="disabled")
                return False
            if self.shred_checkbox_var.get() and not self.shred_validated:
                self.status_feedback_label.configure(text="⚠️ Security verification required below.", text_color="#b78103")
                self.process_button.configure(state="disabled")
                return False
            self.status_feedback_label.configure(text="✨ Verification success: Setup ready.", text_color="#10b981")
            self.process_button.configure(state="normal")
            return True
        else:
            self.status_feedback_label.configure(text="🔒 Ready to decode matching archive context.", text_color="#3b82f6")
            self.process_button.configure(state="normal")
            return True

    def _handle_textbox_focus(self, event):
        if self.mode_var.get() == "Encrypt" and not self.drop_zone_has_custom_text:
            self.drop_zone.configure(state="normal")
            current_content = self.drop_zone.get("1.0", "end")
            marker = "[Click anywhere here to type an optional message to the receiver]"
            if marker in current_content:
                base_text = current_content.split(marker)[0]
                self.drop_zone.delete("1.0", "end")
                self.drop_zone.insert("1.0", base_text + "\n📝 Message to Receiver:\n")
            self.drop_zone_has_custom_text = True

    def handle_drop(self, event):
        try:
            raw_dropped_items = self.root.tk.splitlist(event.data)
            dropped_items = []
            
            for path in raw_dropped_items:
                path = path.strip()
                if path.startswith("file://"):
                    path = urllib.parse.unquote(path[7:])
                if os.path.exists(path):
                    dropped_items.append(path)

            if not dropped_items:
                return
                
            is_package_file = len(dropped_items) == 1 and dropped_items[0].endswith('.grn')
            
            if is_package_file:
                self.input_paths = dropped_items
                self.handle_mode_switch("Decrypt", force_clear=False)
                self.drop_zone.configure(border_width=4, border_color="#3b82f6")
                self.update_display_text()
            else:
                for p in dropped_items:
                    if p not in self.input_paths and not p.endswith('.grn'):
                        self.input_paths.append(p)
                self.handle_mode_switch("Encrypt", force_clear=False)
                self.drop_zone.configure(border_width=4, border_color="#10b981")
                self.update_display_text()
                 
            self._validate_passwords()
        except Exception as e:
            messagebox.showerror("Drop Error", f"Could not register item mapping: {e}")
            self.clear_fields()

    def update_display_text(self):
        self.drop_zone.configure(state="normal")
        
        user_typed_msg = ""
        if self.drop_zone_has_custom_text:
            raw_content = self.drop_zone.get("1.0", "end")
            if "\n📝 Message to Receiver:\n" in raw_content:
                user_typed_msg = raw_content.split("\n📝 Message to Receiver:\n")[1].strip()

        self.drop_zone.delete("1.0", "end")
        
        if not self.input_paths:
            display_text = "\n\n\t\t📥 Secure Drop Zone\n\n\t\tDrag and drop folders or files here to begin...\n\t\tOptional: Type a message here to append a README.txt!"
            self.drop_zone_has_custom_text = False
            self.drop_zone.insert("1.0", display_text)
        elif self.mode_var.get() == "Decrypt":
            display_text = f"\n📦 ARMORED PACKAGE ACTIVE FOR EXTRACTION:\n\n- {os.path.basename(self.input_paths[0])}"
            self.drop_zone.insert("1.0", display_text)
            self.drop_zone.configure(state="disabled")
        else:
            display_text = f"📂 PENDING FILES ALLOCATED FOR SECURING ({len(self.input_paths)} items):\n"
            for p in self.input_paths:
                display_text += f"- {os.path.basename(p)}\n"
            
            if not self.drop_zone_has_custom_text:
                display_text += "\n[Click anywhere here to type an optional message to the receiver]\n"
            else:
                display_text += "\n📝 Message to Receiver:\n"
                
            self.drop_zone.insert("1.0", display_text)
            if user_typed_msg:
                self.drop_zone.insert("end", user_typed_msg)

    def clear_fields(self):
        self.input_paths.clear()
        self.password_entry.delete(0, 'end')
        self.confirm_entry.delete(0, 'end')
        self.shred_checkbox_var.set(False)
        self.inline_warning_frame.pack_forget()
        self.shred_validated = False
        self.drop_zone_has_custom_text = False
        self.passwords_visible = False # Re-mask on clean slate wipe
        self.view_password_btn.configure(text="👁️")
        self.handle_mode_switch("Encrypt", force_clear=True)
        self.progress_bar.set(0)
        self.progress_label.configure(text="Status: Cleaned Session.", text_color="#7f8c8d")
        self._validate_passwords()
        gc.collect()

    def check_queue(self):
        try:
            while True:
                message = self.progress_queue.get_nowait()
                if isinstance(message, tuple):
                    processed, total = message
                    ratio = (processed / total) if total > 0 else 0
                    self.progress_bar.set(ratio)
                    self.progress_label.configure(text=f"Processing Payload Stream... {int(ratio * 100)}%")
                elif isinstance(message, str):
                    self.progress_label.configure(text=message)
        except queue.Empty:
            pass
        finally:
            self.root.after(100, self.check_queue)

    def process(self):
        if not self._validate_passwords():
            return
            
        password = self.password_entry.get()
        mode = self.mode_var.get()
        level = self.security_level.get()
        shred = self.shred_checkbox_var.get() and self.shred_validated
        
        msg_content = ""
        if mode == "Encrypt":
            raw_text = self.drop_zone.get("1.0", "end")
            if self.drop_zone_has_custom_text and "\n📝 Message to Receiver:\n" in raw_text:
                extracted_message = raw_text.split("\n📝 Message to Receiver:\n")[1].strip()
                if extracted_message:
                    msg_content = extracted_message

        if mode == "Encrypt" and not self.input_paths and not msg_content:
            messagebox.showwarning("Empty Submission", "Please drop target files or write a secure message text before execution.")
            return

        self.process_button.configure(state="disabled", text="Working...")
        self.progress_bar.set(0)
        
        default_desktop = os.path.join(os.path.expanduser('~'), 'Desktop')
        
        if mode == "Decrypt":
            output_dir_parent = filedialog.askdirectory(title="Select Destination Extract Root", initialdir=default_desktop)
            if not output_dir_parent:
                self.handle_mode_switch(mode, force_clear=False)
                return
            
            archive_name = os.path.basename(self.input_paths[0]).replace('.grn', '')
            output_directory = os.path.join(output_dir_parent, f"decrypted_{archive_name}")
            args = (mode, password, self.input_paths, level, output_directory, False, "")
        else:
            args = (mode, password, self.input_paths, level, None, shred, msg_content)
            
        thread = threading.Thread(target=self._process_threaded, args=args, daemon=True)
        thread.start()

    def _process_threaded(self, mode: str, password: str, paths: List[str], level: str, output_directory: Optional[str], shred: bool, secure_note: str):
        try:
            if mode == "Encrypt":
                generator = self.crypto_service.encrypt_paths(password, paths, level, shred_source=shred, secure_note=secure_note)
            else:
                generator = self.crypto_service.decrypt_archive(password, paths[0], output_directory, level)

            while True:
                try:
                    processed, total = next(generator)
                    self.progress_queue.put((processed, total))
                except StopIteration as e:
                    result_path = e.value
                    break
                    
            self.progress_queue.put(f"Success! Saved to {os.path.basename(result_path)}")
            self.root.after(0, lambda rp=result_path: messagebox.showinfo("Complete", f"Operation successful!\nSaved to:\n{rp}"))
            self.root.after(0, self.clear_fields)
        except (InvalidTag, argon2.exceptions.VerifyMismatchError):
            self.root.after(0, lambda: messagebox.showerror("Rejection", "Incorrect password or corrupt package structure detected."))
        except PermissionError as pe:
            self.root.after(0, lambda: messagebox.showerror("Boundary Catch", str(pe)))
        except Exception as e:
            err_msg = str(e)
            self.root.after(0, lambda em=err_msg: messagebox.showerror("Error", f"An internal failure occurred:\n{em}"))
        finally:
            self.root.after(0, lambda: self.handle_mode_switch(self.mode_var.get(), force_clear=False))

