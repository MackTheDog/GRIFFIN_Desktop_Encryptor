    def toggle_password_visibility(self):
        """Switches between masked and clear text presentation formats."""
        self.passwords_visible = not self.passwords_visible
        mask_value = "" if self.passwords_visible else "*"
        button_icon = "🙈" if self.passwords_visible else "👁️"
        
        self.password_entry.configure(show=mask_value)
        self.confirm_entry.configure(show=mask_value)
        self.view_password_btn.configure(text=button_icon)

    def _animate_pulsing_border(self):
        if not self.input_paths and not self.drop_zone_has_custom_text:
            self.pulse_step += 0.20  
            factor = (math.sin(self.pulse_step) + 1) / 2
            r = int(164 + (0 - 164) * factor)
            g = int(176 + (168 - 176) * factor)
            b = int(190 + (255 - 190) * factor)
            hex_color = f"#{r:02x}{g:02x}{b:02x}"
            self.drop_zone.configure(border_width=4, border_color=hex_color)
        self.root.after(60, self._animate_pulsing_border)

